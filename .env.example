# ============================================================
# deep-research-agent — Environment Variables
# ============================================================
# Copy this file to .env and fill in real values before running.
#
#   cp .env.example .env
#
# .env is gitignored. Never commit real secrets.
# On Railway: set these via the dashboard Variables panel.
#
# Generate SECRET_KEY with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# ============================================================


# ------------------------------------------------------------
# LLM Inference (HuggingFace Hub / Featherless AI)
# ------------------------------------------------------------
# HuggingFace user access token — used as the API key when
# routing inference requests through Featherless AI.
# Grants access to your full HF account; treat as a root credential.
# Create at: https://huggingface.co/settings/tokens
HF_TOKEN=

# Model served via Featherless AI (routed through HuggingFace Hub).
# Change only if switching to a different hosted model.
LLM_MODEL=Qwen/Qwen3-32B

# Maximum tokens to generate per LLM completion.
LLM_MAX_TOKENS=4096


# ------------------------------------------------------------
# Vector Store (Qdrant)
# ------------------------------------------------------------
# URL of your Qdrant instance.
#   Local dev:  http://localhost:6333
#   Cloud:      https://<cluster-id>.aws.cloud.qdrant.io
QDRANT_URL=http://localhost:6333

# API key for Qdrant (required for cloud; leave empty for unauthenticated local).
QDRANT_API_KEY=

# Name of the Qdrant collection used to store research chunks.
QDRANT_COLLECTION=research_chunks

# Embedding vector dimension — must match the embedding model output.
QDRANT_VECTOR_SIZE=1536


# ------------------------------------------------------------
# Memory Service (Mem0)
# ------------------------------------------------------------
# Mem0 API key.
# Create at: https://app.mem0.ai/dashboard/api-keys
MEM0_API_KEY=

# Number of days before Mem0 session data expires.
MEM0_RETENTION_DAYS=30


# ------------------------------------------------------------
# Web Acquisition (Firecrawl via MCP)
# ------------------------------------------------------------
# Firecrawl API key for web content acquisition.
# Create at: https://www.firecrawl.dev/app/api-keys
FIRECRAWL_API_KEY=


# ------------------------------------------------------------
# FastAPI / Authentication
# ------------------------------------------------------------
# Secret key used to sign JWT tokens.
# Must be at least 32 bytes of random data.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# JWT signing algorithm.
JWT_ALGORITHM=HS256

# JWT token expiry in minutes.
JWT_EXPIRY_MINUTES=60


# ------------------------------------------------------------
# Retrieval
# ------------------------------------------------------------
# Number of candidates to retrieve before reranking.
RETRIEVAL_TOP_K=20

# Number of results to return after reranking.
RETRIEVAL_RERANK_TOP_N=5


# ------------------------------------------------------------
# Observability
# ------------------------------------------------------------
# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Optional: set to "true" to emit structured JSON logs (recommended in production).
LOG_JSON=false


# ------------------------------------------------------------
# LangSmith (AI pipeline tracing — optional)
# ------------------------------------------------------------
# Set to "true" to enable LangSmith tracing for LangGraph nodes,
# LLM calls, tool executions, and memory operations.
# Traces appear in https://smith.langchain.com
LANGCHAIN_TRACING_V2=false

# LangSmith API key — required when LANGCHAIN_TRACING_V2=true.
# Create at: https://smith.langchain.com/settings
LANGCHAIN_API_KEY=
